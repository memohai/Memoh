#!/bin/sh
TOOLKIT="${MEMOH_TOOLKIT_DIR:-/opt/memoh/toolkit}"
CODEX_ACP="$TOOLKIT/acp/lib/node_modules/@agentclientprotocol/codex-acp/dist/index.js"
TOOLKIT_CA_BUNDLE="$TOOLKIT/certs/ca-certificates.crt"

if [ -z "${SSL_CERT_FILE:-}" ] && [ -f "$TOOLKIT_CA_BUNDLE" ]; then
  export SSL_CERT_FILE="$TOOLKIT_CA_BUNDLE"
fi

fallback_codex_acp() {
  old_ifs="$IFS"
  IFS=:
  for dir in $PATH; do
    IFS="$old_ifs"
    [ -n "$dir" ] || dir=.
    case "$dir" in
      "$TOOLKIT/bin") ;;
      *)
        if [ -x "$dir/codex-acp" ]; then
          exec "$dir/codex-acp" "$@"
        fi
        ;;
    esac
    IFS=:
  done
  IFS="$old_ifs"
}

if [ ! -f "$CODEX_ACP" ]; then
  fallback_codex_acp "$@"
  echo "codex-acp is not installed in the Memoh workspace toolkit and no fallback codex-acp command was found: $CODEX_ACP" >&2
  exit 127
fi

case "$(uname -m)" in
  x86_64)  GLIBC_LOADER=/lib64/ld-linux-x86-64.so.2 ;;
  aarch64|arm64) GLIBC_LOADER=/lib/ld-linux-aarch64.so.1 ;;
  *) GLIBC_LOADER= ;;
esac
if ls /lib/ld-musl-*.so.1 >/dev/null 2>&1 && { [ -z "$GLIBC_LOADER" ] || [ ! -e "$GLIBC_LOADER" ]; }; then
  fallback_codex_acp "$@"
  echo "codex-acp requires a glibc workspace image. Use the default Debian workspace image for ACP Codex sessions." >&2
  exit 127
fi
if [ -d "$TOOLKIT/glibc-lib" ]; then
  export LD_LIBRARY_PATH="$TOOLKIT/glibc-lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi
exec "$TOOLKIT/bin/node" "$CODEX_ACP" "$@"
