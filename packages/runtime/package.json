{
  "name": "@memohai/runtime",
  "version": "0.16.0",
  "description": "Embeddable Memoh Remote Runtime SDK and CLI",
  "type": "module",
  "bin": {
    "memoh-runtime": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json && node scripts/copy-proto.mjs",
    "prepack": "pnpm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "esbuild": "0.27.2"
  },
  "packageManager": "pnpm@10.27.0"
}
